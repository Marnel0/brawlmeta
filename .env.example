# Copy this file to .env.local and fill in your values

# Supercell Brawl Stars API — IP-restricted key from developer.brawlstars.com
BRAWL_STARS_API_KEY=your_supercell_api_key_here

# Vercel KV — copy from Vercel dashboard > Storage > KV database > .env.local
KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_token_here

# Secret used to protect the /api/cron/aggregate endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# Full URL of your deployment (used by GitHub Actions to call the cron endpoint)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
